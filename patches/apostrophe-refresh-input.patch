 SDL_Renderer  *ap_get_renderer(void);
 SDL_Window    *ap_get_window(void);
 int            ap_get_screen_width(void);
@@ -4286,6 +4292,104 @@ void ap_hide_window(void) { if (ap__g.window) SDL_HideWindow(ap__g.window); }
 int           ap_get_screen_width(void)  { return ap__g.screen_w; }
 int           ap_get_screen_height(void) { return ap__g.screen_h; }
 
+static void ap__close_input_devices(void) {
+    if (ap__g.controller) {
+        SDL_GameControllerClose(ap__g.controller);
+        ap__g.controller = NULL;
+    }
+
+    for (int i = 0; i < ap__g.joystick_count; i++) {
+        if (ap__g.joysticks[i]) {
+            SDL_JoystickClose(ap__g.joysticks[i]);
+            ap__g.joysticks[i] = NULL;
+        }
+    }
+
+    ap__g.joystick_count = 0;
+    ap__g.joystick = NULL;
+}
+
+static void ap__track_joystick(SDL_Joystick *joy) {
+    if (!joy) return;
+    if (ap__g.joystick_count >= AP__MAX_JOYSTICKS) {
+        SDL_JoystickClose(joy);
+        ap_log("Warning: too many joysticks; closing extra input device");
+        return;
+    }
+    ap__g.joysticks[ap__g.joystick_count++] = joy;
+    if (!ap__g.joystick) ap__g.joystick = joy;
+}
+
+static void ap__open_input_devices(void) {
+    ap__g.controller = NULL;
+    ap__g.joystick = NULL;
+    ap__g.joystick_count = 0;
+
+    /* Open input devices.
+     * On device we prefer raw joystick mapping because SDL GameController
+     * DB mappings can remap face buttons in ways that differ from NextUI's
+     * expected A/B layout on TrimUI hardware.
+     * On device, ALL joysticks are opened (like NextUI's PLAT_initInput) so that
+     * SDL receives keyboard/power events from every registered input device. */
+    int num_joy = SDL_NumJoysticks();
+    #if AP_PLATFORM_IS_DEVICE
+    for (int i = 0; i < num_joy; i++) {
+        SDL_Joystick *joy = SDL_JoystickOpen(i);
+        if (joy) {
+            ap_log("Joystick %d opened: %s", i, SDL_JoystickName(joy));
+            ap__track_joystick(joy);
+        }
+    }
+    #else
+    for (int i = 0; i < num_joy; i++) {
+        if (SDL_IsGameController(i)) {
+            ap__g.controller = SDL_GameControllerOpen(i);
+            if (ap__g.controller) {
+                ap_log("Game controller opened: %s", SDL_GameControllerName(ap__g.controller));
+                /* Also grab underlying joystick for hat/axis fallback */
+                ap__g.joystick = SDL_GameControllerGetJoystick(ap__g.controller);
+                break;
+            }
+        }
+        SDL_Joystick *joy = SDL_JoystickOpen(i);
+        if (joy) {
+            ap_log("Joystick opened: %s", SDL_JoystickName(joy));
+            ap__track_joystick(joy);
+            break;
+        }
+    }
+    #endif
+    ap_log("Input backend: %s",
+           ap__g.controller ? "gamecontroller" :
+           (ap__g.joystick ? "joystick" : "none"));
+}
+
+void ap_refresh_input(void) {
+    ap__close_input_devices();
+
+    SDL_PumpEvents();
+    #if !AP_PLATFORM_IS_DEVICE
+    if (SDL_WasInit(SDL_INIT_GAMECONTROLLER))
+        SDL_QuitSubSystem(SDL_INIT_GAMECONTROLLER);
+    #endif
+    if (SDL_WasInit(SDL_INIT_JOYSTICK))
+        SDL_QuitSubSystem(SDL_INIT_JOYSTICK);
+
+    if (SDL_InitSubSystem(SDL_INIT_JOYSTICK) < 0) {
+        ap_log("Warning: SDL joystick refresh failed: %s", SDL_GetError());
+        return;
+    }
+    #if !AP_PLATFORM_IS_DEVICE
+    if (SDL_InitSubSystem(SDL_INIT_GAMECONTROLLER) < 0) {
+        ap_log("Warning: SDL gamecontroller refresh failed: %s", SDL_GetError());
+    }
+    #endif
+
+    ap__open_input_devices();
+    SDL_JoystickUpdate();
+    SDL_PumpEvents();
+}
